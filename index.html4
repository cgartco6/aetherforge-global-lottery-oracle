<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AETHERFORGE • Global Lottery Oracle v1.1</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Grotesk:wght@500&display=swap');
        :root { --neon-cyan: #00f7ff; --neon-purple: #c300ff; }
        * { transition: all 0.2s ease; }
        body { font-family: 'Inter', system_ui, sans-serif; background: #000; color: #fff; }
        .title-font { font-family: 'Space Grotesk', sans-serif; }
        .number-ball { display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 9999px; font-size: 20px; font-weight: 700; background: linear-gradient(145deg, #00f7ff, #c300ff); color: #000; box-shadow: 0 0 20px #00f7ff; margin: 6px; }
        .extra-ball { background: linear-gradient(145deg, #ff00aa, #ffcc00); }
        canvas#neural-bg { position: fixed; top: 0; left: 0; z-index: -1; opacity: 0.5; }
    </style>
</head>
<body class="overflow-x-hidden">

    <canvas id="neural-bg" width="1920" height="1080"></canvas>

    <!-- NAVBAR -->
    <nav class="border-b border-white/10 bg-black/80 backdrop-blur-xl fixed w-full z-50">
        <div class="max-w-screen-2xl mx-auto px-8 py-5 flex items-center justify-between">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 bg-gradient-to-br from-cyan-400 to-purple-500 rounded-2xl flex items-center justify-center text-xl rotate-45">⚡</div>
                <h1 class="title-font text-3xl tracking-[-2px] neon-text">AETHERFORGE</h1>
            </div>
            <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
                <a onclick="navigateToSection('hero')" class="hover:text-cyan-400 cursor-pointer">NEXUS</a>
                <a onclick="navigateToSection('predict')" class="hover:text-cyan-400 cursor-pointer">PREDICTOR</a>
                <a onclick="navigateToSection('vault')" class="hover:text-cyan-400 cursor-pointer">GLOBAL VAULT</a>
                <a onclick="navigateToSection('swarm')" class="hover:text-cyan-400 cursor-pointer">LIVE SWARM</a>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section id="hero" class="min-h-screen flex items-center pt-20 hero-bg">
        <div class="max-w-screen-2xl mx-auto px-8 text-center">
            <h1 class="title-font text-7xl md:text-8xl leading-none tracking-[-4px] neon-text mb-6">OUT OF THIS WORLD.<br>CALCULATED RISKS.<br><span class="text-amber-400">ANY LOTTERY ON EARTH</span></h1>
            <p class="text-2xl text-white/70 max-w-2xl mx-auto">Real last-5 draws • Frequency trends • Hot/cold patterns • Accurate predictions</p>
            <button onclick="navigateToSection('predict')" class="mt-12 px-10 py-6 bg-gradient-to-r from-amber-400 to-purple-500 text-black font-semibold text-xl rounded-3xl">START NOW →</button>
        </div>
    </section>

    <!-- SELECTOR -->
    <div class="max-w-screen-2xl mx-auto px-8 py-6 border-b border-white/10 bg-black/80">
        <div class="flex items-center gap-x-4 flex-wrap">
            <span class="font-mono text-xs uppercase tracking-widest text-amber-400">CHOOSE LOTTERY</span>
            <select id="global-lottery-select" onchange="switchGlobalLottery()" class="bg-black border border-white/30 focus:border-amber-400 rounded-3xl px-6 py-3 text-lg font-medium"></select>
            <div id="current-lottery-badge" class="text-sm font-mono px-4 py-1 bg-amber-400 text-black rounded-3xl"></div>
        </div>
    </div>

    <!-- PREDICTOR -->
    <section id="predict" class="max-w-screen-2xl mx-auto px-8 py-20">
        <h2 class="title-font text-5xl mb-8">CALCULATED RISK PREDICTOR</h2>
        <div class="grid md:grid-cols-12 gap-8">
            <div class="md:col-span-5 bg-black border border-amber-400/30 rounded-3xl p-8">
                <div id="predicted-header" class="flex justify-between mb-6 font-mono text-sm text-amber-400"></div>
                <div id="predicted-numbers" class="flex flex-wrap justify-center gap-3 mb-8"></div>
                <div id="predicted-extra-section" class="hidden text-xs font-mono mb-4">EXTRA BALL <span id="predicted-extra" class="ml-4"></span></div>
                <button onclick="copyPredicted()" class="w-full py-4 border border-dashed border-amber-400 rounded-3xl text-sm font-medium hover:bg-white/10">📋 COPY NUMBERS</button>
            </div>
            <div class="md:col-span-7 bg-black border border-white/10 rounded-3xl p-8">
                <h3 class="font-mono text-sm mb-6 text-white/70">RISK MATRIX — IF YOU PLAY THESE NUMBERS</h3>
                <div id="risk-matrix" class="space-y-6 text-sm"></div>
            </div>
        </div>
        <button onclick="runFullPrediction()" class="mt-10 px-10 py-5 bg-gradient-to-r from-amber-400 via-purple-500 to-cyan-400 text-black font-semibold rounded-3xl text-lg">RUN NEW PREDICTION</button>
    </section>

    <!-- VAULT -->
    <section id="vault" class="max-w-screen-2xl mx-auto px-8 py-20 bg-white/5">
        <h2 class="title-font text-5xl mb-8">GLOBAL LOTTERY VAULT • LAST 5 DRAWS</h2>
        <div class="overflow-x-auto">
            <table id="vault-table" class="w-full text-sm font-mono border-collapse">
                <thead><tr class="border-b border-white/20"><th class="py-4 px-6 text-left">DATE</th><th class="py-4 px-6 text-left">DRAW</th><th class="py-4 px-6 text-left">NUMBERS</th></tr></thead>
                <tbody id="vault-tbody" class="divide-y divide-white/10"></tbody>
            </table>
        </div>
    </section>

    <!-- SWARM -->
    <section id="swarm" class="max-w-screen-2xl mx-auto px-8 py-20">
        <h2 class="title-font text-5xl mb-8">LIVE AGENTIC SWARM</h2>
        <div id="swarm-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        <button onclick="spawnSwarmAgents()" class="mt-8 px-8 py-4 bg-white/10 hover:bg-white/20 rounded-3xl text-sm font-medium">SPAWN NEW AGENTS</button>
    </section>

